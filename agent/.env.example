# IntentCircles Agent — Environment Variables
# Copy to .env and fill in values

# Agent wallet private key (required for writes)
AGENT_PRIVATE_KEY=0x...

# Contract addresses (set after deployment with forge script)
INTENT_REGISTRY_ADDRESS=0x...
CIRCLE_FACTORY_ADDRESS=0x...
CIRCLE_TRUST_ADDRESS=0x...

# cUSD on Alfajores (default is correct for testnet)
CUSD_ADDRESS=0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1

# Moola lending pool on Alfajores
MOOLA_LENDING_POOL=0x0886f74eEEc443fBb6907fB5528B57C28E813129
