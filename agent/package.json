{
  "name": "intent-circles-agent",
  "version": "0.1.0",
  "description": "Offchain agent for IntentCircles — intent-matched ROSCA manager on Celo",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "dry-run": "DRY_RUN=true bun run src/index.ts",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@types/node": "^25.3.5",
    "hono": "^4.12.5",
    "viem": "^2.47.0"
  }
}
